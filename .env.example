# Bugalizer configuration — copy to .env and adjust.
# Every setting is also settable as an environment variable with the same name.
# Values shown are the defaults from src/bugalizer/config.py.

# --- Server ---
BUGALIZER_HOST=0.0.0.0
BUGALIZER_PORT=8090
BUGALIZER_DEBUG=false

# Comma-separated API keys for X-API-Key auth.
# EMPTY DISABLES AUTH ENTIRELY — always set this on a deployed instance.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
BUGALIZER_API_KEYS=

# --- Storage ---
BUGALIZER_DB_PATH=bugalizer.db
BUGALIZER_REPOS_DIR=./repos
BUGALIZER_CACHE_DIR=./cache

# --- Ollama (Stages 2-3: triage + localization) ---
BUGALIZER_OLLAMA_HOST=http://localhost:11434
BUGALIZER_DEFAULT_TRIAGE_MODEL=qwen2.5-coder:7b
BUGALIZER_DEFAULT_LOCALIZE_MODEL=qwen2.5-coder:7b

# --- Queue worker ---
BUGALIZER_QUEUE_ENABLED=true
BUGALIZER_QUEUE_POLL_SECONDS=5
BUGALIZER_QUEUE_MAX_CONCURRENT=2

# --- Pipeline tuning ---
BUGALIZER_DUPLICATE_THRESHOLD=0.8
BUGALIZER_RETRY_DELAY_SECONDS=60
BUGALIZER_MAX_TRIAGE_RETRIES=3

# --- Localization (Stage 3) ---
BUGALIZER_REPO_MAP_MAX_FILES=50
BUGALIZER_REPO_MAP_MAX_TOKENS=4000
BUGALIZER_REPO_MAP_TTL_HOURS=24
BUGALIZER_LOCALIZE_MAX_FILE_CHARS=8000
BUGALIZER_LOCALIZE_MAX_FILES=3
BUGALIZER_LOCALIZE_CONFIDENCE_THRESHOLD=0.5

# --- Fix proposals (Stage 4, cloud LLM) ---
BUGALIZER_DEFAULT_FIX_MODEL=claude-sonnet-4-6
BUGALIZER_FIX_PROVIDER=anthropic
# Required for Stage 4; without it fix proposals error out cleanly.
BUGALIZER_ANTHROPIC_API_KEY=
BUGALIZER_FIX_MAX_BUNDLE_BYTES=4194304
BUGALIZER_FIX_MAX_FILE_BYTES=524288
BUGALIZER_FIX_ENABLE_PROMPT_CACHING=true

# --- Generic QA_LLM_* fallback layer (optional) ---
# For hosts that configure LLM access generically across apps (e.g. qaagent).
# Explicit BUGALIZER_* settings always win. QA_LLM_MODEL sets the fix
# model+provider atomically; if it is an ollama/... string it also becomes the
# triage/localize model. QA_LLM_API_BASE overrides BUGALIZER_OLLAMA_HOST.
# See docs/phases/architecture.md, "LLM tiering".
#QA_LLM_MODEL=
#QA_LLM_API_BASE=
